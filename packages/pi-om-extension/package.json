{
	"name": "@solvedbydev/pi-om-extension",
	"type": "module",
	"version": "0.1.0",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsdown",
		"clean": "rm -rf dist",
		"prepublishOnly": "npm run clean && npm run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"smoke": "tsx scripts/e2e-smoke.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write ."
	},
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		}
	},
	"pi": {
		"extensions": ["./src/index.ts"]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*"
	},
	"dependencies": {
		"js-tiktoken": "^1.0.21"
	},
	"devDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"tsdown": "^0.21.7",
		"tsx": "^4",
		"typescript": "^6",
		"vitest": "^4"
	}
}
