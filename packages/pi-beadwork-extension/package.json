{
  "name": "@solvedbydev/pi-beadwork-extension",
  "type": "module",
  "version": "0.3.0",
  "description": "Pi extension: beadwork activation, session modes, and orchestrator scaffolding",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "e2e:current-branch-delegate": "node scripts/e2e-current-branch-delegate.mjs",
    "e2e:current-branch-swarm": "node scripts/e2e-current-branch-swarm.mjs",
    "e2e:worktree-preservation": "node scripts/e2e-worktree-preservation.mjs",
    "e2e:current-branch-all": "node scripts/e2e-current-branch-all.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "tsdown": "^0.21.7",
    "typescript": "^6",
    "vitest": "^4"
  }
}
