{
  "name": "@solvedbydev/pi-extensions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsdown -W",
    "build:packages": "tsdown -W -F './packages/*'",
    "build:apps": "tsdown -W -F './apps/*'",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "tsdown -W --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "packages/pi-om-extension/src/index.ts",
      "packages/pi-files-extension/src/index.ts",
      "packages/pi-answer-extension/src/index.ts",
      "packages/pi-beadwork-extension/src/index.ts",
      "packages/pi-exa-extension/src/index.ts"
    ],
    "skills": [
      "skills"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mariozechner/pi-ai": "^0.67.3",
    "@mariozechner/pi-coding-agent": "^0.67.3",
    "@mariozechner/pi-tui": "^0.67.3",
    "@types/node": "^24.12.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  }
}
