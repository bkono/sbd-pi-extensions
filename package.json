{
  "name": "@solvedbydev/pi-extensions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsdown -W",
    "build:packages": "tsdown -W -F './packages/*'",
    "build:apps": "tsdown -W -F './apps/*'",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "tsdown -W --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p packages/pi-hello-world-extension/tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
